# Copy to .env. Never commit the populated file.

OPEN_WEBUI_TAG=v0.10.2
MUNROE_CHAT_PORT=3000
WEBUI_SECRET_KEY=replace-with-a-long-random-secret

# The current Open WebUI license requires its branding to remain unless the
# deployment meets a listed exception or Munroe obtains written branding rights.
# Upstream will display this as "Munroe Chat (Open WebUI)" without such rights.
WEBUI_NAME=Munroe Chat

# Closed by default. Create the first administrator deliberately, then keep
# public signup disabled unless a customer deployment requires it.
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending

# Remote OpenAI-compatible endpoint. Model/provider names remain operator-side.
ENABLE_OPENAI_API=true
OPENAI_API_BASE_URL=
OPENAI_API_KEY=

# Set true and provide OLLAMA_BASE_URL if using a local Ollama server.
ENABLE_OLLAMA_API=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
